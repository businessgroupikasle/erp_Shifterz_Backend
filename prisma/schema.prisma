generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id          String     @id
  name        String
  phone       String
  email       String
  source      String
  service     String
  vehicle     String
  assignedTo  String
  status      String
  notes       String
  budget      String
  date        DateTime
  franchiseId String?
  isDeleted   Boolean    @default(false)
  deletedAt   DateTime?
  franchise   Franchise? @relation(fields: [franchiseId], references: [id])
}

model Invoice {
  id                  String     @id
  type                String
  client              String
  phone               String
  vehicle             String
  service             String
  amount              Float
  gst                 Float
  discount            Float
  status              String
  date                DateTime
  dueDate             DateTime
  notes               String
  gstNumber           String?
  items               Json?
  bankDetails         String?
  paymentTerms        String?
  deliveryTerms       String?
  authorizedSignatory String?
  franchiseId         String?
  isDeleted           Boolean    @default(false)
  deletedAt           DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @default(now()) @updatedAt
  createdBy           String?
  modifiedBy          String?
  cancelledBy         String?
  approvedBy          String?
  franchise           Franchise? @relation(fields: [franchiseId], references: [id])
}

model Payment {
  id          String     @id
  invoiceId   String
  client      String
  amount      Float
  mode        String
  date        DateTime
  ref         String
  notes       String
  franchiseId String?
  isDeleted   Boolean    @default(false)
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt
  createdBy   String?
  franchise   Franchise? @relation(fields: [franchiseId], references: [id])
}

model Inventory {
  id          String     @id
  name        String
  unit        String
  category    String
  stock       Int
  reorder     Int
  cost        Float
  supplier    String
  location    String
  franchiseId String?
  isDeleted   Boolean    @default(false)
  deletedAt   DateTime?
  franchise   Franchise? @relation(fields: [franchiseId], references: [id])
}

model Service {
  id        String    @id
  name      String
  category  String
  price     Float
  duration  String
  warranty  String
  desc      String
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

model Franchise {
  id                String             @id
  name              String
  city              String
  owner             String
  phone             String
  since             DateTime
  revenue           Float
  jobs              Int
  royaltyPct        Float
  status            String
  businessName      String?
  gstNumber         String?
  email             String?
  address           String?
  state             String?
  pinCode           String?
  licenseStatus     String?            @default("Active")
  isDeleted         Boolean            @default(false)
  deletedAt         DateTime?
  appointments      Appointment[]
  attendances       Attendance[]
  carIns            CarIn[]
  customers         Customer[]
  employees         Employee[]
  inventory         Inventory[]
  inventoryRequests InventoryRequest[]
  invoices          Invoice[]
  jobsList          Job[]
  leads             Lead[]
  outPasses         OutPass[]
  payments          Payment[]
}

model Customer {
  id          String     @id
  name        String
  phone       String
  email       String
  vehicle     String
  model       String
  visits      Int
  totalSpend  Float
  lastVisit   DateTime
  franchiseId String?
  isDeleted   Boolean    @default(false)
  deletedAt   DateTime?
  franchise   Franchise? @relation(fields: [franchiseId], references: [id])
}

model CarIn {
  id           String     @id
  vehicle      String
  model        String
  customer     String
  phone        String
  service      String
  technicianIn String
  inTime       DateTime
  outTime      DateTime?
  status       String
  odometer     String
  notes        String
  jobCardId    String
  franchiseId  String?
  isDeleted    Boolean    @default(false)
  deletedAt    DateTime?
  franchise    Franchise? @relation(fields: [franchiseId], references: [id])
}

model Job {
  id               String     @id
  vehicle          String
  customer         String
  service          String
  technician       String
  status           String
  priority         String
  startDate        DateTime
  estCompletion    DateTime
  actualCompletion DateTime?
  notes            String
  photos           String[]
  technicianId     String?
  franchiseId      String?
  createdAt        DateTime   @default(now())
  isDeleted        Boolean    @default(false)
  deletedAt        DateTime?
  franchise        Franchise? @relation(fields: [franchiseId], references: [id])
}

model OutPass {
  id             String     @id
  vehicle        String
  model          String
  customer       String
  phone          String
  service        String
  outTime        DateTime
  securityName   String
  technicianName String
  remarks        String
  issued         Boolean
  carInId        String
  franchiseId    String?
  isDeleted      Boolean    @default(false)
  deletedAt      DateTime?
  franchise      Franchise? @relation(fields: [franchiseId], references: [id])
}

model Setting {
  id             String    @id @default("default")
  companyName    String
  address        String
  phone          String
  email          String
  gstin          String
  gstPct         Float
  currency       String
  agents         String[]
  categories     String[]
  securityGuards String[]
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
}

model Employee {
  id           String          @id
  name         String
  phone        String?
  email        String?
  status       String          @default("Active")
  username     String?         @unique
  password     String?
  role         String          @default("TECHNICIAN")
  hqControlled Boolean         @default(false)
  franchiseId  String?
  isDeleted    Boolean         @default(false)
  deletedAt    DateTime?
  attendances  Attendance[]
  franchise    Franchise?      @relation(fields: [franchiseId], references: [id])
  permission   UserPermission?
}

model Attendance {
  id          String     @id @default(cuid())
  employeeId  String
  date        DateTime
  status      String
  clockIn     DateTime?
  clockOut    DateTime?
  franchiseId String?
  isDeleted   Boolean    @default(false)
  deletedAt   DateTime?
  employee    Employee   @relation(fields: [employeeId], references: [id])
  franchise   Franchise? @relation(fields: [franchiseId], references: [id])
}

model InventoryRequest {
  id                String     @id @default(cuid())
  itemId            String
  quantityRequested Int
  status            String
  date              DateTime
  franchiseId       String?
  isDeleted         Boolean    @default(false)
  deletedAt         DateTime?
  franchise         Franchise? @relation(fields: [franchiseId], references: [id])
}

model Appointment {
  id            String     @id @default(cuid())
  customerId    String?
  customerName  String
  vehicle       String
  scheduledDate DateTime
  service       String
  status        String
  franchiseId   String?
  isDeleted     Boolean    @default(false)
  deletedAt     DateTime?
  franchise     Franchise? @relation(fields: [franchiseId], references: [id])
}

model UserPermission {
  id         String   @id @default(cuid())
  employeeId String   @unique
  modules    String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model RolePermission {
  role        String   @id
  permissions String[]
}

model MemberTransferRequest {
  id              String    @id @default(cuid())
  employeeId      String?
  fromFranchiseId String?
  toFranchiseId   String?
  requestedBy     String
  date            DateTime
  status          String
  username        String?
  password        String?
  newMemberName   String?
  newMemberPhone  String?
  newMemberEmail  String?
  role            String?
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
